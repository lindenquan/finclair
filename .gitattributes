# All text files use LF, both in the repo and in working trees.
# Overrides any core.autocrlf config.
* text=auto eol=lf

# Binary files — never convert
*.png    binary
*.jpg    binary
*.jpeg   binary
*.webp   binary
*.ico    binary
*.gif    binary
*.pdf    binary
*.woff   binary
*.woff2  binary
*.ttf    binary

# Generated — collapse in diffs on GitHub
pnpm-lock.yaml  text eol=lf linguist-generated=true

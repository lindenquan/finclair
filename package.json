{
  "name": "finclair",
  "version": "0.1.0",
  "private": true,
  "license": "ISC",
  "scripts": {
    "preinstall": "git config core.hooksPath scripts",
    "prepare": "svelte-kit sync",
    "dev": "vite dev",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check . && svelte-check --tsconfig ./tsconfig.json",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "cd functions && npx firebase emulators:exec --only firestore --project demo-finclair \"npx vitest run tests/\"",
    "update:check": "pnpm outdated & pnpm --prefix functions outdated",
    "update:all": "pnpm update --latest --interactive && pnpm --prefix functions update --latest --interactive"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "@types/node": "25.6.0",
    "daisyui": "5.5.19",
    "firebase-tools": "15.15.0",
    "jsdom": "29.0.2",
    "svelte": "5.55.4",
    "svelte-check": "4.4.6",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "type": "module",
  "dependencies": {
    "firebase": "12.12.1"
  }
}

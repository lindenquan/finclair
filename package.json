    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.6.0",
    "daisyui": "^5.5.19",
    "jsdom": "^29.0.2",
    "svelte": "^5.19.0",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.4"
